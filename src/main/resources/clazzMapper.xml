<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ascit.tlias.mapper.clazzMapper">


    <select id="getPageByCondition" resultType="com.ascit.tlias.entity.clazz">
        SELECT * FROM clazz as c
        <where>
            <if test="name != null and name != ''">
                AND name LIKE CONCAT('%', #{name}, '%')
            </if>


            <if test="end != null and begin != null">
                AND c.end_date between #{begin} and #{end}
            </if>
        </where>
    </select>
</mapper>